// tsconfig.node.json
{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler", // Match app.json
    "allowSyntheticDefaultImports": true, // Match app.json
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts"] // This is typical
}